# ── App ──
APP_NAME=DocQA
DEBUG=true

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./data/docqa.db

# ── File Storage ──
UPLOAD_DIR=./uploads
VECTOR_STORE_DIR=./data/chroma
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATE_MULTIPLIER=2
RETRIEVAL_VECTOR_WEIGHT=0.65
RETRIEVAL_KEYWORD_WEIGHT=0.35

# ── Server ──
HOST=0.0.0.0
PORT=8000
