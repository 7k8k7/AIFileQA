# ── App ──
APP_NAME=DocQA
DEBUG=true
LOG_LEVEL=INFO

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./data/docqa.db
PROVIDER_SECRET_KEY=
PROVIDER_SECRET_FILE=./data/provider_secret.key

# ── File Storage ──
UPLOAD_DIR=./uploads
VECTOR_STORE_DIR=./data/chroma
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=6
RETRIEVAL_CANDIDATE_MULTIPLIER=2
RETRIEVAL_VECTOR_WEIGHT=0.65
RETRIEVAL_KEYWORD_WEIGHT=0.35
CONVERSATION_RECENT_MESSAGES=8
CONVERSATION_SUMMARY_CHARS=1200
CONVERSATION_HISTORY_CHAR_BUDGET=3000
JOB_POLL_SECONDS=2
JOB_MAX_RETRIES=3
JOB_STALE_SECONDS=300

# ── Server ──
HOST=0.0.0.0
PORT=8000
