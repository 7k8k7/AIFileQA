# ── App ──
DOCQA_APP_NAME=DocQA
DOCQA_DEBUG=true
DOCQA_LOG_LEVEL=INFO

# ── Database ──
DOCQA_DATABASE_URL=sqlite+aiosqlite:///./data/docqa.db
DOCQA_PROVIDER_SECRET_KEY=
DOCQA_PROVIDER_SECRET_FILE=./data/provider_secret.key

# ── File Storage ──
DOCQA_UPLOAD_DIR=./uploads
DOCQA_VECTOR_STORE_DIR=./data/chroma
DOCQA_MAX_UPLOAD_SIZE_MB=50
DOCQA_CHUNK_SIZE=500
DOCQA_CHUNK_OVERLAP=50
DOCQA_RETRIEVAL_TOP_K=6
DOCQA_RETRIEVAL_CANDIDATE_MULTIPLIER=2
DOCQA_RETRIEVAL_VECTOR_WEIGHT=0.65
DOCQA_RETRIEVAL_KEYWORD_WEIGHT=0.35
DOCQA_CONVERSATION_RECENT_MESSAGES=8
DOCQA_CONVERSATION_SUMMARY_CHARS=1200
DOCQA_CONVERSATION_HISTORY_CHAR_BUDGET=3000
DOCQA_JOB_POLL_SECONDS=2
DOCQA_JOB_MAX_RETRIES=3
DOCQA_JOB_STALE_SECONDS=300

# ── Server ──
DOCQA_HOST=0.0.0.0
DOCQA_PORT=8000
